# Pipecat Cloud (required for fallback)
PIPECAT_PUBLIC_KEY=pk_...
PIPECAT_CLOUD_AGENT=quickstart-test

# CORS - set to your dashboard URL (e.g. Vercel)
ALLOWED_ORIGIN=http://localhost:3001

# Local dev: Pipecat runner URL. When set, broker tries local first (uv run bot.py -t daily).
# Default: http://localhost:7860. Omit or set empty in production to skip local.
# LOCAL_RUNNER_URL=http://localhost:7860
